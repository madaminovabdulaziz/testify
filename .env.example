# ---------- Telegram ----------
BOT_TOKEN=replace-with-real-token-from-botfather
WEBHOOK_URL=https://bot.example.com/webhook/replace-with-random-secret-path
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=replace-with-long-random-string
ADMIN_GROUP_ID=-1001234567890

# ---------- nginx (prod only) ----------
# Domain the bot answers HTTPS on. Must match the cert in ./certs.
NGINX_SERVER_NAME=bot.example.com
# Random path segment baked into WEBHOOK_URL (after /webhook/). Generate
# with `openssl rand -hex 24`. The bot also verifies the secret-token
# header — see ARCHITECTURE_SPEC §14.3.
WEBHOOK_SECRET_PATH=replace-with-random-secret-path

# ---------- Database ----------
# Two ways to configure the connection — set EITHER the discrete DB_* vars
# below, OR a single full URL via DATABASE_URL (the app also accepts MYSQL_URL,
# the name Railway's MySQL plugin injects). Whatever driver the URL names is
# rewritten to asyncmy. On Railway the one-liner is simplest:
#   DATABASE_URL=${{ MySQL.MYSQL_URL }}
# DATABASE_URL=mysql://bot:botpass@mysql:3306/attestation
DB_HOST=mysql
DB_PORT=3306
DB_USER=bot
DB_PASSWORD=botpass
DB_NAME=attestation
DB_POOL_SIZE=10
DB_POOL_MAX_OVERFLOW=5

# Used by docker-compose for the MySQL root account; not consumed by the app.
DB_ROOT_PASSWORD=rootpass

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- App ----------
ENV=dev
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=

# ---------- Bot behavior ----------
TEST_DURATION_SECONDS=3200
RECEIPT_MAX_PENDING_PER_USER=3
RECEIPT_REMINDER_AFTER_HOURS=24
BROADCAST_CONCURRENCY=20
BROADCAST_MESSAGES_PER_SECOND=25
